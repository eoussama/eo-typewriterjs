{
  "name": "eo-typewriterjs",
  "type": "module",
  "version": "6.0.0",
  "description": "JavaScript utility for advanced typewriter-like animations.",
  "author": "EOussama",
  "license": "MIT",
  "homepage": "https://github.com/eoussama/eo-typewriterjs#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eoussama/eo-typewriterjs.git"
  },
  "bugs": {
    "url": "https://github.com/eoussama/eo-typewriterjs/issues"
  },
  "keywords": [
    "animation",
    "typewriter",
    "js",
    "library",
    "utility"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "lint": "dx lint",
    "lint:fix": "dx lint --fix",
    "sandbox": "vite --config sandbox/vite.config.ts",
    "docs:api": "typedoc",
    "docs:dev": "vitepress dev docs",
    "docs:build": "pnpm docs:api && vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "prod": "pnpm audit && pnpm lint && pnpm build && pnpm test && pnpm coverage && pnpm docs:build"
  },
  "dependencies": {
    "@eoussama/core": "^0.0.4"
  },
  "devDependencies": {
    "@codemirror/autocomplete": "^6.20.3",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/language": "^6.12.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.43.1",
    "@eoussama/dx": "^0.0.4",
    "@types/node": "^25.9.3",
    "@vitest/coverage-v8": "^4.1.8",
    "codemirror": "^6.0.2",
    "happy-dom": "^20.10.3",
    "oxc-minify": "^0.135.0",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.12.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitepress": "2.0.0-alpha.17",
    "vitest": "^4.1.8",
    "vue": "^3.5.38"
  }
}
